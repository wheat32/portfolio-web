@namespace Portfolio.Components.Layout
@inherits LayoutComponentBase

<div class="opportunity-banner">
    <div class="opportunity-banner-inner">
        <i class="bi bi-briefcase-fill"></i>
        <span>Open to new career opportunities. I'd love to connect!</span>
        <a href="mailto:careers@nicholaspage.dev" class="opportunity-banner-cta">
            Get in Touch <i class="bi bi-arrow-right-short"></i>
        </a>
    </div>
</div>

<NavMenu/>

<div class="page">
    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<Footer/>

<ThemeChangeMenu/>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>